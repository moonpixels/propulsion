{
    "name": "propulsion",
    "version": "0.5.0",
    "type": "module",
    "main": ".opencode/plugins/propulsion.ts",
    "scripts": {
        "checks": "bun run lint && bun run format && bun run test",
        "format": "oxfmt .",
        "format:check": "oxfmt --check .",
        "lint": "oxlint && bun run typecheck",
        "test": "bun test ./tests && bash tests/opencode/run-tests.sh",
        "test:opencode": "bash tests/opencode/run-tests.sh",
        "test:unit": "bun test ./tests",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@opencode-ai/plugin": "^1.4.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "oxfmt": "^0.44.0",
        "oxlint": "^1.59.0",
        "oxlint-tsgolint": "^0.20.0",
        "typescript": "^6.0.2"
    },
    "packageManager": "bun@1.3.11"
}
